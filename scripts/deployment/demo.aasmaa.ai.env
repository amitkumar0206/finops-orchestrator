# Demo deployment defaults for demo.aasmaa.ai
# Usage:
#   source scripts/deployment/demo.aasmaa.ai.env
#   bash scripts/deployment/deploy-demo-only.sh

export AWS_PROFILE=aiverse-deployer
export AWS_REGION=ap-south-1
export DEPLOYMENT_BACKEND=ec2
export DOMAIN_NAME=demo.aasmaa.ai
export HOSTED_ZONE_ID=Z00723291RSJHAKVIGJBI
export CREATE_ACM_CERTIFICATE=false

# Set per-region certificate ARN before deploy (required for HTTPS listener on ALB)
# export CERTIFICATE_ARN=arn:aws:acm:ap-south-1:152924644003:certificate/...

# Set the AWS account IDs you want visible in demo scope
export DEMO_ALLOWED_ACCOUNT_IDS=123456789012

# Low-cost Bedrock default for demo
export BEDROCK_MODEL=meta.llama3-8b-instruct-v1:0

# Demo access protection (browser login prompt via HTTP Basic Auth)
export BASIC_AUTH_USERNAME=demo
# Optional: set BASIC_AUTH_PASSWORD to use your own password. If omitted, deploy script generates one.
# export BASIC_AUTH_PASSWORD=ChangeMe123!
export BASIC_AUTH_PARAM_NAME=/aasmaa/demo/basic-auth/htpasswd
