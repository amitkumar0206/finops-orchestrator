{
    "commands": [
        "set -e",
        "cd /opt/aasmaa-demo",
        "sed -i \"s/AWS_CUR_DATABASE: 'cost_usage_db'/AWS_CUR_DATABASE: 'cost_and_usage_db'/g\" docker-compose.yml",
        "sed -i \"s/AWS_CUR_TABLE: 'cur_data'/AWS_CUR_TABLE: 'costandusagereport'/g\" docker-compose.yml",
        "grep -q 'ATHENA_WORKGROUP:' docker-compose.yml || (awk '/ATHENA_OUTPUT_LOCATION:/{print; print \"                ATHENA_WORKGROUP: primary\"; next}1' docker-compose.yml > docker-compose.yml.tmp && mv docker-compose.yml.tmp docker-compose.yml)",
        "docker-compose up -d backend",
        "sleep 6",
        "docker inspect aasmaa-backend --format \"{{range .Config.Env}}{{println .}}{{end}}\" | grep -E \"DEMO_MODE=|DATABASE_ENABLED=|CHAT_HISTORY_ENABLED=|ATHENA_WORKGROUP=|AWS_CUR_DATABASE=|AWS_CUR_TABLE=\" || true",
        "curl -sS http://localhost:8000/health",
        "docker logs --tail 80 aasmaa-backend"
    ]
}