{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "billingreports.amazonaws.com"
      },
      "Action": [
        "s3:GetBucketAcl",
        "s3:GetBucketPolicy"
      ],
      "Resource": "arn:aws:s3:::${CUR_BUCKET_NAME}",
      "Condition": {
        "StringEquals": {
          "aws:SourceArn": "arn:aws:cur:${AWS_REGION}:${BILLING_ACCOUNT_ID}:definition/*",
          "aws:SourceAccount": "${BILLING_ACCOUNT_ID}"
        }
      }
    },
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "billingreports.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::${CUR_BUCKET_NAME}/*",
      "Condition": {
        "StringEquals": {
          "aws:SourceArn": "arn:aws:cur:${AWS_REGION}:${BILLING_ACCOUNT_ID}:definition/*",
          "aws:SourceAccount": "${BILLING_ACCOUNT_ID}"
        }
      }
    }
  ]
}
