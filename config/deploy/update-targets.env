# Shared deployment targets used by update scripts.
# Override any value via environment variable when invoking scripts.

AWS_REGION="${AWS_REGION:-us-east-1}"
AWS_ACCOUNT_ID="${AWS_ACCOUNT_ID:-152924644003}"
ECR_REGISTRY="${ECR_REGISTRY:-${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com}"

# Production (full infra + services)
PROD_STACK_NAME="${PROD_STACK_NAME:-aasmaa}"
PROD_SERVICES_STACK_NAME="${PROD_SERVICES_STACK_NAME:-aasmaa-services}"
PROD_CLUSTER_NAME="${PROD_CLUSTER_NAME:-aasmaa-cluster}"
PROD_BACKEND_SERVICE="${PROD_BACKEND_SERVICE:-aasmaa-backend}"
PROD_FRONTEND_SERVICE="${PROD_FRONTEND_SERVICE:-aasmaa-frontend}"
PROD_MAIN_TEMPLATE="${PROD_MAIN_TEMPLATE:-infrastructure/cloudformation/main-stack.yaml}"
PROD_SERVICES_TEMPLATE="${PROD_SERVICES_TEMPLATE:-infrastructure/cloudformation/ecs-services.yaml}"
PROD_ENV_FILE="${PROD_ENV_FILE:-deployment.env}"

# Demo (barebones in-place service rollout only)
DEMO_STACK_NAME="${DEMO_STACK_NAME:-aasmaa}"
DEMO_CLUSTER_NAME="${DEMO_CLUSTER_NAME:-aasmaa-cluster}"
DEMO_BACKEND_SERVICE="${DEMO_BACKEND_SERVICE:-aasmaa-backend}"
DEMO_FRONTEND_SERVICE="${DEMO_FRONTEND_SERVICE:-aasmaa-frontend}"
DEMO_URL="${DEMO_URL:-demo.aasmaa.ai}"
DEMO_ALB_DNS="${DEMO_ALB_DNS:-aasmaa-alb-1244254274.us-east-1.elb.amazonaws.com}"
