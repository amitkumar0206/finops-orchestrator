# Shell defaults for DemoOnly/demo deployments.
# Values only apply when corresponding env vars are not already set.

STACK_NAME="${STACK_NAME:-aasmaa-demo-barebones}"
AWS_REGION="${AWS_REGION:-us-east-1}"
ENVIRONMENT="${ENVIRONMENT:-development}"
ENV_FILE="${ENV_FILE:-deployment.demo.env}"
BEDROCK_MODEL="${BEDROCK_MODEL:-us.amazon.nova-lite-v1:0}"
USE_CUSTOM_DOMAIN="${USE_CUSTOM_DOMAIN:-false}"
CLEANUP_EXISTING_RDS="${CLEANUP_EXISTING_RDS:-true}"
BUILD_IMAGES="${BUILD_IMAGES:-true}"
DISABLE_ROLLBACK="${DISABLE_ROLLBACK:-true}"

# Stable demo URL configuration
DEMO_DOMAIN_NAME="${DEMO_DOMAIN_NAME:-demo.aasmaa.ai}"
DEMO_HOSTED_ZONE_ID="${DEMO_HOSTED_ZONE_ID:-Z00723291RSJHAKVIGJBI}"

# Pre-existing ACM certificate for demo.aasmaa.ai (HTTPS)
# Region: us-east-1 — ISSUED, covers demo.aasmaa.ai
CERTIFICATE_ARN="${CERTIFICATE_ARN:-arn:aws:acm:us-east-1:152924644003:certificate/b1e4830f-631e-4f1d-92f0-1a055d2d06fa}"
