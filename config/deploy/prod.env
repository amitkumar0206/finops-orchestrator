# Shell defaults for production/mainline deployments.
# Values only apply when corresponding env vars are not already set.

STACK_NAME="${STACK_NAME:-aasmaa}"
AWS_REGION="${AWS_REGION:-us-east-1}"
ENVIRONMENT="${ENVIRONMENT:-production}"
ENV_FILE="${ENV_FILE:-deployment.env}"
BEDROCK_MODEL="${BEDROCK_MODEL:-us.amazon.nova-pro-v1:0}"
USE_CUSTOM_DOMAIN="${USE_CUSTOM_DOMAIN:-true}"
